{
  "name": "forma-luna",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": [
    "backend"
  ],
  "scripts": {
    "postinstall": "npm run db:generate",
    "dev": "vite",
    "dev:api": "npm run dev --prefix backend",
    "db:up": "docker compose -f backend/docker-compose.yml up -d",
    "db:down": "docker compose -f backend/docker-compose.yml down",
    "db:migrate": "npm run db:migrate --workspace formaluna-backend",
    "db:generate": "npm run prisma:generate --workspace formaluna-backend",
    "build": "tsc && vite build",
    "vercel-build": "cd backend && npx prisma generate && npm run build && cd .. && npm run build",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview"
  },
  "dependencies": {
    "framer-motion": "^11.0.0",
    "lucide-react": "^0.300.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.20.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@vitejs/plugin-react": "^4.2.1",
    "typescript": "^5.2.2",
    "vite": "^5.0.8"
  }
}
