NODE_ENV=development
PORT=8080
APP_ORIGIN=http://localhost:5173

# lax = same host dev (Vite + API on localhost different ports still cross-origin for cookies; use none if login fails)
# none = production when frontend is on another domain (e.g. https://formaluna.vercel.app → API on Railway). Requires HTTPS on API.
SESSION_COOKIE_SAMESITE=lax

# --- Production example (separate API host) ---
# APP_ORIGIN=https://formaluna.vercel.app
# SESSION_COOKIE_SAMESITE=none

# Auth
JWT_SECRET=replace_me_with_a_long_random_secret
JWT_EXPIRES_IN=7d

# Postgres (local via docker compose)
DATABASE_URL=postgresql://formaluna:formaluna_password@localhost:5433/formaluna?schema=public

# Admin bootstrap (first-run seed)
ADMIN_EMAIL=admin@formaluna.local
ADMIN_PASSWORD=replace_me

# S3 / R2 (S3-compatible)
S3_REGION=auto
S3_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
S3_BUCKET=formaluna
S3_ACCESS_KEY_ID=replace_me
S3_SECRET_ACCESS_KEY=replace_me
S3_PUBLIC_BASE_URL=https://<your-public-domain-or-r2-public-url>

# Encrypt secret settings stored in DB (SMTP password, etc.)
ENCRYPTION_KEY=replace_me_with_32+_chars
