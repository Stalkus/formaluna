NODE_ENV=development
PORT=8080
APP_ORIGIN=http://localhost:5173

# lax = same host dev (Vite + API on localhost different ports still cross-origin for cookies; use none if login fails)
# none = production when frontend is on another domain (e.g. https://formaluna.vercel.app → API on Railway). Requires HTTPS on API.
SESSION_COOKIE_SAMESITE=lax

# --- Production example (separate API host) ---
# APP_ORIGIN=https://formaluna.vercel.app
# SESSION_COOKIE_SAMESITE=none

# Auth (min 20 chars — Vercel will crash the API if JWT_SECRET is shorter)
JWT_SECRET=replace_me_with_at_least_20_characters_here
JWT_EXPIRES_IN=7d

# Postgres (local via docker compose)
DATABASE_URL=postgresql://formaluna:formaluna_password@localhost:5433/formaluna?schema=public

# Prisma `directUrl` — same as DATABASE_URL for local Docker. On Supabase, use the direct host only for
# migrations (see Supabase → Connect → ORMs → Prisma): `db.<project-ref>.supabase.co:5432`, not the pooler.
# URL-encode special characters in the password. Optional on Vercel runtime (falls back to DATABASE_URL).
DIRECT_URL=postgresql://formaluna:formaluna_password@localhost:5433/formaluna?schema=public

# Supabase pooled URL for Vercel (transaction pooler :6543 + pgbouncer). Example shape:
# DATABASE_URL=postgresql://postgres.<ref>:PASSWORD@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true
# DIRECT_URL=postgresql://postgres:PASSWORD@db.<ref>.supabase.co:5432/postgres
# The app normalizes Supabase hosts (sslmode, pooler port 5432→6543) via resolveDatabaseUrl.ts.

# Admin bootstrap (first-run seed)
ADMIN_EMAIL=admin@formaluna.local
ADMIN_PASSWORD=replace_me

# S3 / R2 (S3-compatible)
S3_REGION=auto
S3_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
S3_BUCKET=formaluna
S3_ACCESS_KEY_ID=replace_me
S3_SECRET_ACCESS_KEY=replace_me
S3_PUBLIC_BASE_URL=https://<your-public-domain-or-r2-public-url>

# Encrypt secret settings stored in DB (SMTP password, etc.)
ENCRYPTION_KEY=replace_me_with_32+_chars
