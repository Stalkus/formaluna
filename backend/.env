NODE_ENV=development
PORT=8080
APP_ORIGIN=http://localhost:5173

# Auth
JWT_SECRET=dev_only_change_me_to_a_long_random_secret_1234567890
JWT_EXPIRES_IN=7d

# Postgres (local via docker compose)
DATABASE_URL=postgresql://formaluna:formaluna_password@localhost:5433/formaluna?schema=public

# Admin bootstrap (first-run seed)
ADMIN_EMAIL=admin@formaluna.local
ADMIN_PASSWORD=admin_password_change_me

# S3 / R2 (S3-compatible) - optional for local dev
S3_REGION=auto
S3_ENDPOINT=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_BASE_URL=

ENCRYPTION_KEY=dev_only_replace_with_32_chars_or_more_123456
