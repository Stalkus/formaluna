generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  B2B
  ADMIN
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum AssetKind {
  PRODUCT_IMAGE
  PRODUCT_TECH_SHEET
  PROJECT_IMAGE
  OTHER
}

model User {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  role           UserRole
  approvalStatus ApprovalStatus @default(PENDING)
  approvedAt     DateTime?

  email        String @unique
  passwordHash String

  displayName String?
  companyName String?
  phone       String?
  vatNumber   String?
  pricingTier String?

  lastLoginAt DateTime?
}

model Product {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  slug        String  @unique
  sku         String?
  name        String
  category    String?
  description String?

  packshotUrl  String?
  lifestyleUrl String?

  isNovaTrade     Boolean @default(false)
  isStudioProject Boolean @default(false)

  isPublished Boolean @default(false)

  // Pricing visibility rule (extra requirement beyond guide)
  hidePricing Boolean @default(false)

  // Optional stored price; you can also compute by tier later
  priceCents Int?
  currency   String? // e.g. "EUR"

  // Flexible technical fields (guide suggests JSONB)
  specs Json?

  assets       Asset[]
  projectLinks ProjectProduct[]
  relatedFrom  RelatedProduct[] @relation("related_from")
  relatedTo    RelatedProduct[] @relation("related_to")
}

model Project {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  slug          String   @unique
  title         String
  categoryTags  String?
  coverImageUrl String?
  description   String?
  galleryUrls   String[]

  isPublished Boolean @default(false)

  assets       Asset[]
  productLinks ProjectProduct[]
}

model RelatedProduct {
  productId        String
  relatedProductId String

  product        Product @relation("related_from", fields: [productId], references: [id], onDelete: Cascade)
  relatedProduct Product @relation("related_to", fields: [relatedProductId], references: [id], onDelete: Cascade)

  @@id([productId, relatedProductId])
  @@index([relatedProductId])
}

model ProjectProduct {
  projectId String
  productId String

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@id([projectId, productId])
  @@index([productId])
}

model Asset {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  kind AssetKind

  objectKey   String // key inside bucket
  contentType String?
  byteSize    Int?

  publicUrl String? // derived from base URL + key (or signed URL strategy)

  label     String?
  sortOrder Int     @default(0)

  productId String?
  projectId String?

  product Product? @relation(fields: [productId], references: [id], onDelete: Cascade)
  project Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([projectId])
}

model Page {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  slug        String @unique
  title       String
  contentJson Json?
}

model Setting {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  key      String  @unique
  value    String?
  isSecret Boolean @default(false)
}
