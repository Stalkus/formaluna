{
  "buildCommand": "npm run vercel-build",
  "outputDirectory": "dist",
  "functions": {
    "api/index.ts": {
      "includeFiles": "backend/dist/**"
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index?path=$1" },
    { "source": "/api", "destination": "/api/index" },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
